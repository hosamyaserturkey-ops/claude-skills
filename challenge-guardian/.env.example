# Copy this file to .env and fill in your values. NEVER commit .env to git.

PROPR_API_KEY=pk_live_your_key_here
# PROPR_BUILDER_ID=builder_your_code_here

GUARDIAN_TELEGRAM_TOKEN=123456:your_telegram_bot_token
GUARDIAN_TELEGRAM_CHAT_ID=123456789
GUARDIAN_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# Guard every active account (recommended for hosted deployments):
GUARDIAN_ALL=true
GUARDIAN_PRESET=1step
# GUARDIAN_POLL_INTERVAL=10

# Daily digest hour in UTC (0-23), or 'off':
# GUARDIAN_DIGEST_HOUR=20

# DANGER ZONE — trading actions are off by default. Enabling them lets the
# bot close positions (Telegram /close and /flatten, plus auto-flatten):
# GUARDIAN_ACTIONS=on
# GUARDIAN_AUTO_FLATTEN_AT=0.95

# Multi-tenant mode only (python -m guardian --multi-tenant). The worker reads
# the tenants table and writes dashboard data using the SECRET service-role key
# (Project Settings → API → service_role). Never expose this key client-side.
# SUPABASE_URL=https://trbemqbxutdiqsslcups.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
